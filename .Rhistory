resultado <- data %>%
as_survey_design(
ids = !!sym(u_ids),
strata = !!sym(u_strata),
weights = expr,
nest = TRUE
) %>%
group_by(pobreza_cat) %>%
summarize(porcentaje = survey_mean(na.rm = TRUE) * 100) %>%
mutate(ano = as.character(anio)) # Etiqueta para el gráfico
return(resultado)
}
