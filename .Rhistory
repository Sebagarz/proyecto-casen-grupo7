obtener_resumen <- function(ruta_rds, anio, u_ids = "varunit", u_strata = "varstrat") {
cat("Calculando resultados para el año:", anio, "\n")
data <- readRDS(ruta_rds)
# 1. Filtros básicos de limpieza
data <- data %>%
filter(!is.na(pobreza_2013)) %>%
filter(!is.na(expr), expr > 0)
# 2. Filtro de exclusión oficial (SOLO si la variable p1 existe)
if ("p1" %in% colnames(data)) {
data <- data %>% filter(p1 != 11)
} else {
warning(paste("Variable 'p1' no encontrada en el año", anio, ". El resultado podría variar 0,1%."))
}
# 3. Categorías y Diseño
data <- data %>%
mutate(pobreza_cat = case_when(
pobreza_2013 == 1 ~ "Pobreza extrema",
pobreza_2013 == 2 ~ "Pobreza no extrema",
pobreza_2013 == 3 ~ "No pobres",
TRUE ~ NA_character_
))
resultado <- data %>%
as_survey_design(ids = !!sym(u_ids), strata = !!sym(u_strata), weights = expr, nest = TRUE) %>%
group_by(pobreza_cat) %>%
summarize(porcentaje = survey_mean(na.rm = TRUE) * 100) %>%
mutate(ano = as.character(anio))
return(resultado)
}
